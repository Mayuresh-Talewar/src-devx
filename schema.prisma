datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model MenuItem {
  id    Int    @id @default(autoincrement())
  name  String
  price Float
  image String
}

model Reservation {
  id     Int    @id @default(autoincrement())
  name   String
  email  String
  phone  String
  date   DateTime
}

model Order {
  id    Int    @id @default(autoincrement())
  items OrderItem[]
}

model OrderItem {
  id       Int      @id @default(autoincrement())
  orderId  Int
  order    Order    @relation(fields: [orderId], references: [id])
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])
  menuItemId Int
}